{
  "manifest_version": 3,
  "name": "ThreadHook MVP",
  "description": "현재 페이지 정보를 추출해 스레드 초안을 생성하는 MVP 확장앱",
  "version": "0.1.0",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://127.0.0.1:3000/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "ThreadHook",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
